# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build output (will be generated during build)
dist/
dist-ssr/
.angular/

# Testing files (not needed for production build)
coverage/
.nyc_output/
karma.conf.js
src/test.ts
*.spec.ts
tsconfig.spec.json
e2e/

# IDE configurations
.vscode/
.idea/
*.swp
*.swo
.editorconfig

# Git files
.git/
.gitignore
.gitattributes

# Environment files (should be handled separately)
.env
.env.local
.env.*.local

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Documentation (not needed for build)
README.md
docs/
LICENSE

# Docker files (avoid recursive copy)
Dockerfile
.dockerignore
docker-compose*.yml

# CI/CD (not needed in container)
.github/

# TypeScript build info (will be regenerated)
*.tsbuildinfo

# IMPORTANT: DO NOT EXCLUDE these files - they are required for Angular build:
# - tsconfig.json
# - tsconfig.app.json
# - angular.json
# - package.json
# - package-lock.json
# - .browserslistrc (needed for browser compatibility)
# - src/ directory
